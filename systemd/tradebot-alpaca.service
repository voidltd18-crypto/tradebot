[Unit]
Description=TradeBot Alpaca Instance
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/tradebot
EnvironmentFile=/home/pi/tradebot/env/alpaca.env
ExecStart=/home/pi/tradebot/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
